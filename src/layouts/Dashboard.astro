---
import "../styles/global.css";

interface CardItem {
  name: string;
  desc?: string;
  cfaHref?: string | null;
  autheliaHref?: string | null;
  icon?: string;
}

interface Section {
  title: string;
  type?: "links";
  items: any[];
}

interface Props {
  pageTitle: string;
  headerLabel: string;
  sections: Section[];
  navLink?: { href: string; label: string };
  redirectAdminTo?: string;
}

const { pageTitle, headerLabel, sections, navLink, redirectAdminTo } = Astro.props;

function mono(item: CardItem): string {
  if (item.icon) return item.icon;
  return [...item.name][0] ?? "·";
}
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style>
      :root {
        --bg: #ffffff;
        --fg: #18181b;
        --muted: #71717a;
        --faint: #a1a1aa;
        --border: #ededee;
        --tile: #f4f4f5;
        --hover: #fafafa;
        --accent: #18181b;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", "PingFang SC", sans-serif;
        -webkit-font-smoothing: antialiased;
        line-height: 1.5;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .wrap { width: 100%; max-width: 1080px; margin: 0 auto; padding: 0 40px; }

      header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding: 34px 0 8px;
      }
      .brand { font-size: 13px; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--fg); }
      .head-right { display: flex; align-items: baseline; gap: 22px; }
      .clock { font-variant-numeric: tabular-nums; font-size: 13px; color: var(--faint); letter-spacing: 0.04em; }
      .tabs { display: inline-flex; gap: 14px; font-size: 12px; letter-spacing: 0.04em; }
      .tabs button {
        background: none; border: none; padding: 0; cursor: pointer;
        font: inherit; font-size: 12px; color: var(--faint); letter-spacing: 0.04em;
        transition: color 140ms ease;
      }
      .tabs button.active { color: var(--fg); }
      .tabs button:hover:not(.active) { color: var(--muted); }

      main { flex: 1; padding: 26px 0 52px; }

      .cat { margin-bottom: 22px; }
      .cat-label {
        font-size: 11px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase;
        color: var(--faint); margin: 0 0 8px;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(216px, 1fr));
        gap: 1px;
        align-items: start;
      }
      .card {
        display: flex; align-items: center; gap: 11px;
        padding: 9px 11px;
        border-radius: 9px;
        text-decoration: none; color: inherit;
        transition: background 140ms ease;
      }
      .card:hover { background: var(--hover); }
      .card.disabled { opacity: 0.32; pointer-events: none; }
      .card.disabled .desc::after { content: " · 未配置"; color: var(--faint); }

      /* 点击复制地址的卡 */
      .copy-card { cursor: pointer; -webkit-user-select: none; user-select: none; }
      .copy-card.copied .desc { color: var(--fg); }
      .mono {
        flex: none;
        width: 30px; height: 30px;
        border-radius: 8px;
        background: var(--tile);
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 600; color: var(--muted);
      }
      .txt { min-width: 0; display: flex; flex-direction: column; }
      .name { font-size: 14px; font-weight: 500; color: var(--fg); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .desc { font-size: 12px; color: var(--faint); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

      /* 纯链接名（无图标无描述，紧凑横排） */
      .linklist { display: flex; flex-wrap: wrap; gap: 7px 22px; padding: 2px 4px; }
      .linklist a {
        font-size: 13px; color: var(--muted); text-decoration: none;
        transition: color 140ms ease;
      }
      .linklist a:hover { color: var(--fg); }

      footer { font-size: 11px; color: var(--faint); font-variant-numeric: tabular-nums; }
      .footer-built {
        border-top: 1px solid var(--border);
        padding: 16px 0 28px;
        display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
      }
      .footer-built a { color: var(--muted); text-decoration: none; }
      .footer-built a:hover { color: var(--fg); }

      @media (max-width: 640px) {
        .wrap { padding: 0 20px; }
        header { padding: 22px 0 8px; flex-wrap: wrap; gap: 10px 16px; }
        .brand { flex: 1 0 auto; }
        main { padding: 18px 0 44px; }
        .grid { grid-template-columns: 1fr; gap: 0; }
        .cat { margin-bottom: 20px; }
        .linklist { gap: 10px 18px; }
        .footer-built { gap: 8px 16px; padding-bottom: 24px; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header>
        <span class="brand">{headerLabel}</span>
        <div class="head-right">
          <div class="tabs" role="tablist" aria-label="登录链路">
            <button type="button" data-tab="authelia" class="active" role="tab">Authelia</button>
            <button type="button" data-tab="cfa" role="tab">CF Access</button>
          </div>
          <span class="clock" id="clock">--:--:--</span>
        </div>
      </header>

      <main>
        {sections.map((s) => (
          <section class="cat">
            <p class="cat-label">{s.title}</p>
            {s.type === "links" ? (
              <div class="linklist">
                {s.items.map((it) => (
                  <a href={it.href} target="_blank" rel="noopener noreferrer">{it.name}</a>
                ))}
              </div>
            ) : (
              <div class="grid">
                {s.items.map((app) => (
                  app.copy ? (
                    <div class="card copy-card" tabindex="0" role="button" data-copy={app.copy} title={app.copy}>
                      <span class="mono">{mono(app)}</span>
                      <span class="txt">
                        <span class="name">{app.name}</span>
                        <span class="desc">{app.desc}</span>
                      </span>
                    </div>
                  ) : (
                    <a
                      class="card"
                      href={app.autheliaHref ?? app.cfaHref ?? "#"}
                      data-authelia={app.autheliaHref ?? ""}
                      data-cfa={app.cfaHref ?? ""}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <span class="mono">{mono(app)}</span>
                      <span class="txt">
                        <span class="name">{app.name}</span>
                        <span class="desc">{app.desc}</span>
                      </span>
                    </a>
                  )
                ))}
              </div>
            )}
          </section>
        ))}
        <slot name="post-sections" />
      </main>

      <footer>
        <slot name="footer-extra" />
        <div class="footer-built">
          <span id="date">—</span>
          {navLink && (<a href={navLink.href}>{navLink.label}</a>)}
          <a href="https://neckbozia.cloudflareaccess.com">App Launcher</a>
          <a href="https://neckbozia.cloudflareaccess.com/cdn-cgi/access/logout">logout</a>
        </div>
      </footer>
    </div>

    {redirectAdminTo && (
      <script is:inline define:vars={{ target: redirectAdminTo }}>
        fetch('/cdn-cgi/access/get-identity', { credentials: 'same-origin' })
          .then(r => r.ok ? r.json() : null)
          .then(id => {
            const adminEmails = ['neckbozia@gmail.com', 'neckbozia@outlook.com'];
            if (id && adminEmails.includes(id.email)) {
              window.location.replace(target);
            }
          })
          .catch(() => {});
      </script>
    )}

    <script is:inline>
      (function () {
        var KEY = "dashTab";
        function apply(tab) {
          document.querySelectorAll(".tabs button").forEach(function (b) {
            b.classList.toggle("active", b.dataset.tab === tab);
          });
          document.querySelectorAll("a.card").forEach(function (c) {
            if (!("authelia" in c.dataset) && !("cfa" in c.dataset)) return;
            var a = c.dataset.authelia || "";
            var f = c.dataset.cfa || "";
            var href = tab === "cfa" ? f : a;
            if (href) {
              c.href = href;
              c.classList.remove("disabled");
            } else {
              c.removeAttribute("href");
              c.classList.add("disabled");
            }
          });
        }
        document.querySelectorAll(".tabs button").forEach(function (btn) {
          btn.addEventListener("click", function () {
            var tab = btn.dataset.tab;
            apply(tab);
            try { localStorage.setItem(KEY, tab); } catch (e) {}
          });
        });
        var saved = "authelia";
        try { saved = localStorage.getItem(KEY) || "authelia"; } catch (e) {}
        apply(saved);
      })();

      /* copy 卡：点击复制地址，闪一下「已复制」 */
      (function () {
        function flash(c, msg) {
          var d = c.querySelector(".desc");
          if (!d) return;
          if (c._t) { clearTimeout(c._t); } else { c._orig = d.textContent; }
          d.textContent = msg;
          c.classList.add("copied");
          c._t = setTimeout(function () {
            d.textContent = c._orig;
            c.classList.remove("copied");
            c._t = null;
          }, 1500);
        }
        function copy(c) {
          var txt = c.dataset.copy || "";
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(txt).then(function () { flash(c, "已复制 ✓"); })
              .catch(function () { flash(c, "复制失败"); });
          } else {
            try {
              var ta = document.createElement("textarea");
              ta.value = txt; document.body.appendChild(ta); ta.select();
              document.execCommand("copy"); document.body.removeChild(ta);
              flash(c, "已复制 ✓");
            } catch (e) { flash(c, "复制失败"); }
          }
        }
        document.querySelectorAll(".copy-card").forEach(function (c) {
          c.addEventListener("click", function () { copy(c); });
          c.addEventListener("keydown", function (e) {
            if (e.key === "Enter" || e.key === " ") { e.preventDefault(); copy(c); }
          });
        });
      })();
    </script>

    <script is:inline>
      function tick() {
        const d = new Date();
        const pad = (n) => String(n).padStart(2, "0");
        const el = document.getElementById("clock");
        if (el) el.textContent = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
        const w = ["日","一","二","三","四","五","六"][d.getDay()];
        const de = document.getElementById("date");
        if (de) de.textContent = `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} 周${w}`;
      }
      tick();
      setInterval(tick, 1000);
    </script>
  </body>
</html>
