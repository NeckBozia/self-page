---
import "../styles/global.css";

interface Item {
  name: string;
  desc: string;
  cfaHref?: string | null;
  autheliaHref?: string | null;
}

interface Section {
  title: string;
  items: Item[];
}

interface Props {
  pageTitle: string;
  headerLabel: string;
  sections: Section[];
  navLink?: { href: string; label: string };
  redirectAdminTo?: string;
}

const { pageTitle, headerLabel, sections, navLink, redirectAdminTo } = Astro.props;
const buildTime = new Date().toISOString();
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style>
      :root {
        --bg: #ffffff;
        --fg: #1a1a1a;
        --muted: #6a6a72;
        --card: #fafafa;
        --card-hover: #f0f0f2;
        --border: #e4e4e7;
        --border-hover: #a8a8b0;
        --accent: #4a8a9c;
      }
      * { box-sizing: border-box; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      header {
        max-width: 1024px;
        width: 100%;
        margin: 0 auto;
        padding: 20px 32px 0;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 24px;
      }
      header h1 { justify-self: start; }
      header .tabs { justify-self: center; margin: 0; }
      header .clock { justify-self: end; }
      h1 {
        font-size: 14px;
        font-weight: 500;
        color: var(--muted);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 0;
      }
      .clock {
        font-variant-numeric: tabular-nums;
        font-size: 14px;
        color: var(--muted);
        letter-spacing: 0.02em;
      }
      main {
        max-width: 1024px;
        width: 100%;
        margin: 0 auto;
        padding: 24px 32px 40px;
        flex: 1;
      }
      section { margin-bottom: 28px; }
      section:last-of-type { margin-bottom: 0; }

      /* 桌面单屏不滚；移动端走默认滚动 */
      @media (min-width: 768px) {
        html, body { height: 100dvh; }
        body { overflow: hidden; }
        main { overflow: hidden; min-height: 0; }
      }
      h2 {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.16em;
        text-transform: uppercase;
        margin: 0 0 14px;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--border);
      }
      .tabs {
        display: inline-flex;
        gap: 2px;
        padding: 3px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
      }
      .tabs button {
        padding: 6px 14px;
        font: inherit;
        font-size: 12px;
        color: var(--muted);
        background: transparent;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: background 160ms ease, color 160ms ease;
        letter-spacing: 0.04em;
      }
      .tabs button.active {
        background: var(--bg);
        color: var(--fg);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
      }
      .tabs button:hover:not(.active) {
        color: var(--fg);
      }
      a.card.disabled {
        opacity: 0.35;
        pointer-events: none;
        cursor: not-allowed;
      }
      a.card.disabled .desc::after {
        content: " · 未配置";
        color: var(--muted);
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 12px;
      }
      a.card {
        display: block;
        padding: 18px 18px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: inherit;
        text-decoration: none;
        transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
        position: relative;
        overflow: hidden;
      }
      a.card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, transparent 0%, rgba(74, 138, 156, 0.08) 100%);
        opacity: 0;
        transition: opacity 200ms ease;
        pointer-events: none;
      }
      a.card:hover {
        border-color: var(--border-hover);
        background: var(--card-hover);
        transform: translateY(-1px);
      }
      a.card:hover::before { opacity: 1; }
      .name {
        font-size: 15px;
        font-weight: 500;
        margin: 0 0 6px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .name::before {
        content: "";
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent);
        opacity: 0.6;
        transition: opacity 160ms ease;
      }
      a.card:hover .name::before { opacity: 1; }
      .desc {
        font-size: 12px;
        color: var(--muted);
        margin: 0;
        line-height: 1.5;
      }
      footer {
        text-align: center;
        padding: 24px;
        font-size: 11px;
        color: #999;
        font-variant-numeric: tabular-nums;
      }
      footer a {
        color: #888;
        text-decoration: none;
        border-bottom: 1px dotted #bbb;
      }
      footer a:hover { color: var(--accent); border-color: var(--accent); }
    </style>
  </head>
  <body>
    <header>
      <h1>{headerLabel}</h1>
      <div class="tabs" role="tablist" aria-label="登录链路">
        <button type="button" data-tab="authelia" class="active" role="tab">Authelia</button>
        <button type="button" data-tab="cfa" role="tab">CF Access</button>
      </div>
      <div class="clock" id="clock">--:--:--</div>
    </header>
    <main>
      {sections.map((s) => (
        <section>
          <h2>{s.title}</h2>
          <div class="grid">
            {s.items.map((app) => (
              <a
                class="card"
                href={app.autheliaHref ?? app.cfaHref ?? "#"}
                data-authelia={app.autheliaHref ?? ""}
                data-cfa={app.cfaHref ?? ""}
                target="_blank"
                rel="noopener noreferrer"
              >
                <p class="name">{app.name}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
      <slot name="post-sections" />
    </main>
    <footer>
      built <span id="ts">{buildTime}</span>
      {navLink && (<> · <a href={navLink.href}>{navLink.label}</a></>)}
      · <a href="https://neckbozia.cloudflareaccess.com">App Launcher</a>
      · <a href="https://neckbozia.cloudflareaccess.com/cdn-cgi/access/logout">logout</a>
    </footer>
    {redirectAdminTo && (
      <script is:inline define:vars={{ target: redirectAdminTo }}>
        fetch('/cdn-cgi/access/get-identity', { credentials: 'same-origin' })
          .then(r => r.ok ? r.json() : null)
          .then(id => {
            const adminEmails = ['neckbozia@gmail.com', 'neckbozia@outlook.com'];
            if (id && adminEmails.includes(id.email)) {
              window.location.replace(target);
            }
          })
          .catch(() => {});
      </script>
    )}
    <script is:inline>
      (function () {
        var KEY = "dashTab";
        function apply(tab) {
          document.querySelectorAll(".tabs button").forEach(function (b) {
            b.classList.toggle("active", b.dataset.tab === tab);
          });
          document.querySelectorAll("a.card").forEach(function (c) {
            var href = c.dataset[tab];
            if (href) {
              c.href = href;
              c.classList.remove("disabled");
            } else {
              c.removeAttribute("href");
              c.classList.add("disabled");
            }
          });
        }
        document.querySelectorAll(".tabs button").forEach(function (btn) {
          btn.addEventListener("click", function () {
            var tab = btn.dataset.tab;
            apply(tab);
            try { localStorage.setItem(KEY, tab); } catch (e) {}
          });
        });
        var saved = "authelia";
        try { saved = localStorage.getItem(KEY) || "authelia"; } catch (e) {}
        apply(saved);
      })();
    </script>
    <script is:inline>
      function tick() {
        const d = new Date();
        const pad = (n) => String(n).padStart(2, "0");
        const t = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
        const w = ["日","一","二","三","四","五","六"][d.getDay()];
        const date = `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} 周${w}`;
        const el = document.getElementById("clock");
        if (el) el.textContent = `${date}  ${t}`;
      }
      tick();
      setInterval(tick, 1000);
    </script>
  </body>
</html>
