---
import Dashboard from "../layouts/Dashboard.astro";

// 每张卡两条链路：
//   cfaHref      —— 走 CF Tunnel + CF Access SSO（橙云，长名）
//   autheliaHref —— 走家公网 :66 + Authelia / gateway nginx 直连（灰云短名，快）
// 缺一边时 layout 会把卡片在对应 tab 下变灰显示「未配置」。
const sections = [
  {
    title: "Ruoyi OA",
    items: [
      {
        name: "Ruoyi OA",
        desc: "OA 后台 — admin SPA",
        cfaHref: "https://ruoyi.neckbozia.com",
        autheliaHref: "https://ya.neckbozia.com:66",
      },
      {
        name: "Spring Boot Admin",
        desc: "ruoyi-server 实时监控",
        cfaHref: "https://ruoyilog.neckbozia.com/admin/applications",
        autheliaHref: "https://sba.neckbozia.com:66/admin/applications",
      },
      {
        name: "Grafana",
        desc: "性能监控 / PVE + 容器指标",
        cfaHref: "https://grafana.neckbozia.com",
        autheliaHref: "https://gfn.neckbozia.com:66",
      },
    ],
  },
  {
    title: "Downloads",
    items: [
      {
        name: "qBittorrent",
        desc: "qb WebUI",
        cfaHref: "https://qbittorrent.neckbozia.com/",
        autheliaHref: "https://qb.neckbozia.com:66/",
      },
      {
        name: "Transmission",
        desc: "tr WebUI",
        cfaHref: "https://transmission.neckbozia.com/transmission/web/",
        autheliaHref: "https://tr.neckbozia.com:66/transmission/web/",
      },
    ],
  },
  {
    title: "Tools",
    items: [
      {
        name: "Claude Code",
        desc: "AI 编程助手 — 浏览器内编程",
        cfaHref: "https://claudecode.neckbozia.com",
        autheliaHref: "https://cc.neckbozia.com:66",
      },
      {
        name: "知识库",
        desc: "Quartz personal KB",
        cfaHref: "https://wiki.neckbozia.com",
        autheliaHref: "https://kb.neckbozia.com:66",
      },
    ],
  },
  {
    title: "Dashboards",
    items: [
      {
        name: "Homepage",
        desc: "主 dashboard（service 集成丰富）",
        cfaHref: "https://homepage.neckbozia.com",
        autheliaHref: "https://hp.neckbozia.com:66",
      },
      {
        name: "mihomo",
        desc: "metacubexd — 代理面板 / 流量 / 规则命中",
        cfaHref: "https://mihomo.neckbozia.com/ui/metacubexd/",
        autheliaHref: "https://mhn.neckbozia.com:66/ui/metacubexd/",
      },
    ],
  },
];
---

<Dashboard
  pageTitle="Home"
  headerLabel="Home / Astro"
  sections={sections}
  navLink={{ href: "/guest/", label: "guest" }}

>
  <section slot="footer-extra" id="otp-section">
    <div id="otp-list">
      <span class="otp-empty">loading…</span>
    </div>
    <div id="otp-controls">
      <span id="otp-last-refresh">—</span>
      <button type="button" id="otp-refresh-btn" title="刷新 OTP" aria-label="刷新">⟳</button>
    </div>
  </section>
  <div slot="footer-extra" id="user-mgmt-row">
    <span class="lbl">User Management</span>
    <a class="um-cfa-only" href="https://admin.neckbozia.com" target="_blank" rel="noopener">CFA</a>
    <span class="sep um-cfa-only">·</span>
    <a id="um-authelia"
       data-cfa="/authelia/"
       data-authelia="https://users.neckbozia.com:66/"
       target="_blank" rel="noopener">Authelia</a>
  </div>
  <style slot="footer-extra" is:global>
    /* OTP strip + user mgmt row — 字号比 footer 大一档，inner DOM 由 JS 注入故 is:global */
    #otp-section {
      margin: 0;
      padding: 14px 0 0;
      border-top: 1px solid var(--border);
      font-size: 13px;
      color: #999;
      font-variant-numeric: tabular-nums;
      line-height: 1.7;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    #otp-list { flex: 1; min-width: 0; text-align: center; }
    #otp-controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
      font-size: 12px;
      color: #888;
    }
    #otp-last-refresh { font-variant-numeric: tabular-nums; }
    #otp-refresh-btn {
      background: transparent;
      border: none;
      padding: 2px 4px;
      font-size: 16px;
      line-height: 1;
      color: #888;
      cursor: pointer;
      font-family: inherit;
    }
    #otp-refresh-btn:hover { color: var(--accent); }
    #otp-refresh-btn:disabled {
      opacity: 0.5;
      cursor: wait;
    }
    #otp-section .otp-row { display: block; }
    #otp-section .otp-empty { font-size: 13px; color: #999; }
    #otp-section .otp-link {
      color: #888;
      text-decoration: none;
      border-bottom: 1px dotted #bbb;
    }
    #otp-section .otp-link:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
    #user-mgmt-row {
      text-align: center;
      padding: 0 0 8px;
      font-size: 13px;
      color: #888;
    }
    #user-mgmt-row .lbl { color: #888; margin-right: 8px; }
    #user-mgmt-row .sep { margin: 0 4px; color: #bbb; }
    #user-mgmt-row a {
      color: #888;
      text-decoration: none;
      border-bottom: 1px dotted #bbb;
    }
    #user-mgmt-row a:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
  </style>
  <script is:inline slot="footer-extra">
    (function () {
      var lastEl = document.getElementById("otp-last-refresh");
      var btn = document.getElementById("otp-refresh-btn");
      var listEl = document.getElementById("otp-list");

      function pad(n) { return String(n).padStart(2, "0"); }
      function fmtTime(d) {
        var n = new Date();
        var sameDay = d.getFullYear() === n.getFullYear() && d.getMonth() === n.getMonth() && d.getDate() === n.getDate();
        var hm = pad(d.getHours()) + ":" + pad(d.getMinutes());
        return sameDay ? hm : (pad(d.getMonth() + 1) + "-" + pad(d.getDate()) + " " + hm);
      }

      function render(items) {
        if (!items.length) {
          listEl.innerHTML = '<span class="otp-empty">no notifications</span>';
          return;
        }
        listEl.innerHTML = items.map(function (it) {
          var parts = [];
          if (it.ts) parts.push(it.ts);
          if (it.subject) parts.push(it.subject);
          if (it.to) parts.push("→ " + it.to);
          if (it.otp) parts.push(it.otp);
          if (it.link) parts.push('<a class="otp-link" href="' + it.link + '" target="_blank" rel="noopener noreferrer">open link</a>');
          return '<div class="otp-row">' + parts.join(" · ") + "</div>";
        }).join("");
      }

      function load() {
        btn.disabled = true;
        fetch("/_notifications.json", { credentials: "same-origin" })
          .then(function (r) { return r.ok ? r.json() : { items: [] }; })
          .then(function (j) {
            render(j.items || []);
            lastEl.textContent = fmtTime(new Date());
          })
          .catch(function () {
            listEl.innerHTML = '<span class="otp-empty">读取失败</span>';
            lastEl.textContent = fmtTime(new Date()) + " (失败)";
          })
          .finally(function () { btn.disabled = false; });
      }

      btn.addEventListener("click", load);
      load();
    })();

    /* User Management 行跟 layout 顶部 tab 联动 */
    (function () {
      var KEY = "dashTab";
      var anchor = document.getElementById("um-authelia");
      function apply(tab) {
        document.querySelectorAll("#user-mgmt-row .um-cfa-only").forEach(function (el) {
          el.style.display = tab === "cfa" ? "" : "none";
        });
        if (anchor) anchor.href = anchor.dataset[tab] || "#";
      }
      var saved = "authelia";
      try { saved = localStorage.getItem(KEY) || "authelia"; } catch (e) {}
      apply(saved);
      document.querySelectorAll(".tabs button").forEach(function (b) {
        b.addEventListener("click", function () { apply(b.dataset.tab); });
      });
    })();
  </script>
</Dashboard>
