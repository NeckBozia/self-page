---
import Dashboard from "../layouts/Dashboard.astro";

// 每张卡两条链路：
//   cfaHref      —— 走 CF Tunnel + CF Access SSO（橙云，长名）
//   autheliaHref —— 走家公网 :66 + Authelia / gateway nginx 直连（灰云短名，快）
// 缺一边时 layout 会把卡片在对应 tab 下变灰显示「未配置」。
const sections = [
  {
    title: "Yudao OA",
    items: [
      {
        name: "Yudao OA",
        desc: "OA 后台 — admin SPA",
        cfaHref: "https://ruoyi.neckbozia.com",
        autheliaHref: "https://ya.neckbozia.com:66",
      },
      {
        name: "Spring Boot Admin",
        desc: "yudao-server 实时监控",
        cfaHref: "https://ruoyilog.neckbozia.com/admin/applications",
        autheliaHref: "https://sba.neckbozia.com:66/admin/applications",
      },
      {
        name: "Grafana",
        desc: "性能监控 / PVE + 容器指标",
        cfaHref: "https://grafana.neckbozia.com",
        autheliaHref: "https://gfn.neckbozia.com:66",
      },
    ],
  },
  {
    title: "Downloads",
    items: [
      {
        name: "qBittorrent",
        desc: "qb WebUI",
        cfaHref: "https://qbittorrent.neckbozia.com/",
        autheliaHref: "https://qb.neckbozia.com:66/",
      },
      {
        name: "Transmission",
        desc: "tr WebUI",
        cfaHref: "https://transmission.neckbozia.com/transmission/web/",
        autheliaHref: "https://tr.neckbozia.com:66/transmission/web/",
      },
    ],
  },
  {
    title: "Tools",
    items: [
      {
        name: "Claude Code",
        desc: "AI 编程助手 — 浏览器内编程",
        cfaHref: "https://claudecode.neckbozia.com",
        autheliaHref: "https://cc.neckbozia.com:66",
      },
      {
        name: "知识库",
        desc: "Quartz personal KB",
        cfaHref: "https://wiki.neckbozia.com",
        autheliaHref: "https://kb.neckbozia.com:66",
      },
    ],
  },
  {
    title: "Dashboards",
    items: [
      {
        name: "Homepage",
        desc: "主 dashboard（service 集成丰富）",
        cfaHref: "https://homepage.neckbozia.com",
        autheliaHref: "https://hp.neckbozia.com:66",
      },
      {
        name: "Access Admin",
        desc: "白名单 Web UI",
        cfaHref: "https://admin.neckbozia.com",
        autheliaHref: null,
      },
      {
        name: "mihomo",
        desc: "metacubexd — 代理面板 / 流量 / 规则命中",
        cfaHref: "https://mihomo.neckbozia.com/ui/metacubexd/",
        autheliaHref: "https://mhn.neckbozia.com:66/ui/metacubexd/",
      },
    ],
  },
];
---

<Dashboard
  pageTitle="Admin"
  headerLabel="Admin / Astro"
  sections={sections}
  navLink={{ href: "/guest/", label: "guest" }}
>
  <section slot="post-sections" id="otp-section">
    <div id="otp-list">
      <span class="otp-empty">loading…</span>
    </div>
  </section>
  <style slot="post-sections" is:global>
    /* OTP strip — footer-tier 字号/字重，紧贴 main 末尾，单行 inline 排版 */
    /* is:global because the inner DOM is JS-injected at runtime and won't
       carry Astro's data-astro-cid scope attribute. */
    #otp-section {
      margin: 0;
      padding: 12px 0 0;
      border-top: 1px solid var(--border);
      text-align: center;
      font-size: 11px;
      color: #999;
      font-variant-numeric: tabular-nums;
      line-height: 1.7;
    }
    #otp-section .otp-row {
      display: block;
    }
    #otp-section .otp-empty {
      font-size: 11px;
      color: #999;
    }
    #otp-section .otp-link {
      color: #888;
      text-decoration: none;
      border-bottom: 1px dotted #bbb;
    }
    #otp-section .otp-link:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
  </style>
  <script is:inline slot="post-sections">
    (function () {
      function render(items) {
        var list = document.getElementById("otp-list");
        if (!list) return;
        if (!items.length) {
          list.innerHTML = '<span class="otp-empty">no notifications</span>';
          return;
        }
        list.innerHTML = items
          .map(function (it) {
            var parts = [];
            if (it.ts) parts.push(it.ts);
            if (it.subject) parts.push(it.subject);
            if (it.to) parts.push("→ " + it.to);
            if (it.otp) parts.push(it.otp);
            if (it.link)
              parts.push(
                '<a class="otp-link" href="' +
                  it.link +
                  '" target="_blank" rel="noopener noreferrer">open link</a>'
              );
            return '<div class="otp-row">' + parts.join(" · ") + "</div>";
          })
          .join("");
      }
      function load() {
        fetch("/_notifications.json", { credentials: "same-origin" })
          .then(function (r) { return r.ok ? r.json() : { items: [] }; })
          .then(function (j) { render(j.items || []); })
          .catch(function () {
            var list = document.getElementById("otp-list");
            if (list) list.innerHTML = '<span class="otp-empty">读取失败</span>';
          });
      }
      load();
      setInterval(load, 30000);
    })();
  </script>
</Dashboard>
