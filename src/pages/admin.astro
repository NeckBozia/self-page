---
import Dashboard from "../layouts/Dashboard.astro";

// 每张卡两条链路：
//   cfaHref      —— 走 CF Tunnel + CF Access SSO（橙云，长名）
//   autheliaHref —— 走家公网 :66 + Authelia / gateway nginx 直连（灰云短名，快）
// 缺一边时 layout 会把卡片在对应 tab 下变灰显示「未配置」。
const sections = [
  {
    title: "Yudao OA",
    items: [
      {
        name: "Yudao OA",
        desc: "OA 后台 — admin SPA",
        cfaHref: "https://ruoyi.neckbozia.com",
        autheliaHref: "https://ya.neckbozia.com:66",
      },
      {
        name: "Spring Boot Admin",
        desc: "yudao-server 实时监控",
        cfaHref: "https://ruoyilog.neckbozia.com/admin/applications",
        autheliaHref: "https://sba.neckbozia.com:66/admin/applications",
      },
      {
        name: "Grafana",
        desc: "性能监控 / PVE + 容器指标",
        cfaHref: "https://grafana.neckbozia.com",
        autheliaHref: "https://gfn.neckbozia.com:66",
      },
    ],
  },
  {
    title: "Downloads",
    items: [
      {
        name: "qBittorrent",
        desc: "qb WebUI",
        cfaHref: "https://qbittorrent.neckbozia.com/",
        autheliaHref: "https://qb.neckbozia.com:66/",
      },
      {
        name: "Transmission",
        desc: "tr WebUI",
        cfaHref: "https://transmission.neckbozia.com/transmission/web/",
        autheliaHref: "https://tr.neckbozia.com:66/transmission/web/",
      },
    ],
  },
  {
    title: "Tools",
    items: [
      {
        name: "Claude Code",
        desc: "AI 编程助手 — 浏览器内编程",
        cfaHref: "https://claudecode.neckbozia.com",
        autheliaHref: "https://cc.neckbozia.com:66",
      },
      {
        name: "知识库",
        desc: "Quartz personal KB",
        cfaHref: "https://wiki.neckbozia.com",
        autheliaHref: "https://kb.neckbozia.com:66",
      },
    ],
  },
  {
    title: "Dashboards",
    items: [
      {
        name: "Homepage",
        desc: "主 dashboard（service 集成丰富）",
        cfaHref: "https://homepage.neckbozia.com",
        autheliaHref: "https://hp.neckbozia.com:66",
      },
      {
        name: "Access Admin",
        desc: "白名单 Web UI",
        cfaHref: "https://admin.neckbozia.com",
        autheliaHref: null,
      },
      {
        name: "mihomo",
        desc: "metacubexd — 代理面板 / 流量 / 规则命中",
        cfaHref: "https://mihomo.neckbozia.com",
        autheliaHref: "https://mhn.neckbozia.com:66/ui/metacubexd/",
      },
    ],
  },
];
---

<Dashboard
  pageTitle="Admin"
  headerLabel="Admin / Astro"
  sections={sections}
  navLink={{ href: "/", label: "public" }}
>
  <section slot="post-sections" id="otp-section">
    <h2>Authelia OTP (最近 5)</h2>
    <div class="grid" id="otp-grid">
      <div class="otp-empty">loading…</div>
    </div>
  </section>
  <style slot="post-sections" is:global>
    /* OTP section — minimal footprint, footer-tier aesthetic */
    /* is:global because the .otp-card / .otp-link DOM is JS-injected at runtime
       and won't carry Astro's data-astro-cid scope attribute, so scoped
       selectors wouldn't match. */
    #otp-section .grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 8px;
    }
    #otp-section .otp-card {
      display: block;
      padding: 6px 10px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 6px;
      cursor: default;
    }
    #otp-section .otp-code {
      font-family: "SF Mono", ui-monospace, Menlo, Consolas, monospace;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.06em;
      color: var(--muted);
      margin: 0 0 2px;
    }
    #otp-section .otp-meta {
      font-size: 9px;
      color: var(--muted);
      line-height: 1.45;
      word-break: break-all;
      margin: 0;
    }
    #otp-section .otp-empty {
      font-size: 10px;
      color: var(--muted);
      padding: 6px 10px;
    }
    #otp-section .otp-link {
      display: inline-block;
      font-size: 9px;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px dotted var(--border-hover);
      margin-top: 2px;
      word-break: break-all;
    }
    #otp-section .otp-link:hover {
      color: var(--fg);
      border-bottom-color: var(--fg);
    }
  </style>
  <script is:inline slot="post-sections">
    (function () {
      function render(items) {
        var grid = document.getElementById("otp-grid");
        if (!grid) return;
        if (!items.length) {
          grid.innerHTML = '<div class="otp-empty">暂无 OTP / 通知（notification.txt 空）</div>';
          return;
        }
        grid.innerHTML = items
          .map(function (it) {
            var code = it.otp ? '<p class="otp-code">' + it.otp + "</p>" : "";
            var link = it.link
              ? '<a class="otp-link" href="' +
                it.link +
                '" target="_blank" rel="noopener noreferrer">open link</a>'
              : "";
            var meta =
              "<p class=\"otp-meta\">" +
              (it.subject || "(no subject)") +
              "<br>→ " +
              (it.to || "(unknown)") +
              "<br>" +
              (it.ts || "") +
              "</p>";
            return '<div class="otp-card">' + code + meta + link + "</div>";
          })
          .join("");
      }
      function load() {
        fetch("/admin/_notifications.json", { credentials: "same-origin" })
          .then(function (r) { return r.ok ? r.json() : { items: [] }; })
          .then(function (j) { render(j.items || []); })
          .catch(function () {
            var grid = document.getElementById("otp-grid");
            if (grid) grid.innerHTML = '<div class="otp-empty">读取失败</div>';
          });
      }
      load();
      setInterval(load, 30000);
    })();
  </script>
</Dashboard>
