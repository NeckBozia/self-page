---
import Dashboard from "../layouts/Dashboard.astro";

// 每张卡两条链路：
//   cfaHref      —— 走 CF Tunnel + CF Access SSO（橙云，长名）
//   autheliaHref —— 走家公网 :66 + Authelia / gateway nginx 直连（灰云短名，快）
// 缺一边时 layout 会把卡片在对应 tab 下变灰显示「未配置」。
const sections = [
  {
    title: "Ruoyi OA",
    items: [
      {
        name: "Ruoyi OA",
        desc: "OA 后台 — admin SPA",
        cfaHref: "https://ruoyi.neckbozia.com",
        autheliaHref: "https://ry.neckbozia.com:66",
      },
      {
        name: "Spring Boot Admin",
        desc: "ruoyi-server 实时监控",
        cfaHref: "https://ruoyilog.neckbozia.com/admin/applications",
        autheliaHref: "https://ryl.neckbozia.com:66/admin/applications",
      },
      {
        name: "Grafana",
        desc: "性能监控 / PVE + 容器指标",
        cfaHref: "https://grafana.neckbozia.com",
        autheliaHref: "https://gfn.neckbozia.com:66",
      },
    ],
  },
  {
    title: "Synology",
    items: [
      {
        name: "DSM",
        desc: "Synology 管理面板",
        cfaHref: "https://dsm.neckbozia.com:66",
        autheliaHref: "https://dsm.neckbozia.com:66",
      },
      {
        name: "qBittorrent",
        desc: "qb WebUI",
        cfaHref: "https://qbittorrent.neckbozia.com/",
        autheliaHref: "https://qb.neckbozia.com:66/",
      },
      {
        name: "Transmission",
        desc: "tr WebUI",
        cfaHref: "https://transmission.neckbozia.com/transmission/web/",
        autheliaHref: "https://tr.neckbozia.com:66/transmission/web/",
      },
      {
        // WebDAV 是挂载协议、非浏览器 UI，所以做成「点击复制地址」的 copy 卡
        name: "WebDAV",
        desc: "点击复制地址",
        copy: "https://wd.neckbozia.com:66",
      },
    ],
  },
  {
    title: "Services",
    items: [
      {
        name: "mihomo",
        desc: "metacubexd — 代理面板 / 流量 / 规则命中",
        cfaHref: "https://mihomo.neckbozia.com/ui/metacubexd/",
        autheliaHref: "https://mhn.neckbozia.com:66/ui/metacubexd/",
      },
      {
        name: "Claude Code",
        desc: "AI 编程助手 — 浏览器内编程",
        cfaHref: "https://claudecode.neckbozia.com",
        autheliaHref: "https://cc.neckbozia.com:66",
      },
      {
        name: "知识库",
        desc: "Quartz personal KB",
        cfaHref: "https://wiki.neckbozia.com",
        autheliaHref: "https://kb.neckbozia.com:66",
      },
      {
        name: "客户端下载",
        desc: "Clash 客户端 · mac/win/安卓/iOS",
        icon: "↓",
        cfaHref: "https://dl.neckbozia.com",
        autheliaHref: "https://dl.neckbozia.com",
      },
      {
        name: "Sub2API",
        desc: "Claude 中转 — 上游账号 / 定时测试 / API key 池",
        cfaHref: "https://ai.neckbozia.com/admin",
        autheliaHref: "https://ai.neckbozia.com/admin",
      },
    ],
  },
  {
    title: "Links",
    type: "links",
    items: [
      { name: "IPRisk", href: "https://iprisk.top/" },
      { name: "Scamalytics", href: "https://scamalytics.com/" },
      { name: "LisaHost", href: "https://lisahost.com/clientarea.php" },
      { name: "CF API Tokens", href: "https://dash.cloudflare.com/profile/api-tokens" },
      { name: "CF Zero Trust", href: "https://one.dash.cloudflare.com/" },
      { name: "搬瓦工库存", href: "https://stock.bwg.net/" },
      { name: "3x-ui", href: "https://lisa.neckbozia.com/aRn9X3DQvgTd0dgMKk/panel/" },
      { name: "bestproxy", href: "https://bestproxy.com/zh/" },
    ],
  },
];
---

<Dashboard
  pageTitle="Home"
  headerLabel="Home / Astro"
  sections={sections}
  navLink={{ href: "/guest/", label: "guest" }}

>
  <section slot="footer-extra" id="otp-section">
    <div id="otp-list">
      <span class="otp-empty">loading…</span>
    </div>
    <div id="otp-controls">
      <span id="otp-last-refresh">—</span>
      <button type="button" id="otp-refresh-btn" title="刷新 OTP" aria-label="刷新">⟳</button>
    </div>
  </section>
  <section slot="footer-extra" id="usage-section">
    <span class="usage-label">Claude 用量</span>
    <div id="usage-vals">
      <span id="usage-5h" class="usage-cell">5h --</span>
      <span class="usage-sep">·</span>
      <span id="usage-7d" class="usage-cell">week --</span>
    </div>
    <div id="usage-controls">
      <span id="usage-last">—</span>
      <button type="button" id="usage-refresh-btn" title="主动刷新 (sub2api → anthropic)" aria-label="刷新">⟳</button>
    </div>
  </section>
  <style slot="footer-extra" is:global>
    #usage-section {
      margin: 0;
      padding: 14px 0 0;
      border-top: 1px solid var(--border);
      font-size: 13px;
      color: #999;
      font-variant-numeric: tabular-nums;
      line-height: 1.7;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    #usage-section .usage-label { color: #888; flex-shrink: 0; }
    #usage-vals { flex: 1; display: flex; gap: 12px; min-width: 0; }
    #usage-vals .usage-sep { color: #bbb; }
    #usage-vals .usage-cell { color: #999; }
    #usage-controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
      font-size: 12px;
      color: #888;
    }
    #usage-last { font-variant-numeric: tabular-nums; }
    #usage-refresh-btn {
      background: transparent;
      border: none;
      padding: 2px 4px;
      font-size: 16px;
      line-height: 1;
      color: #888;
      cursor: pointer;
      font-family: inherit;
    }
    #usage-refresh-btn:hover { color: var(--accent); }
    #usage-refresh-btn:disabled { opacity: 0.5; cursor: wait; }
    #usage-section .usage-link {
      color: #888;
      text-decoration: none;
      border-bottom: 1px dotted #bbb;
    }
    #usage-section .usage-link:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
  </style>
  <script is:inline slot="footer-extra">
    (function () {
      var BASE = "https://usage.neckbozia.com";
      var fiveEl = document.getElementById("usage-5h");
      var sevenEl = document.getElementById("usage-7d");
      var lastEl = document.getElementById("usage-last");
      var btn = document.getElementById("usage-refresh-btn");

      function pad(n) { return String(n).padStart(2, "0"); }
      function fmtTime(d) {
        var n = new Date();
        var sameDay = d.getFullYear() === n.getFullYear() && d.getMonth() === n.getMonth() && d.getDate() === n.getDate();
        var hm = pad(d.getHours()) + ":" + pad(d.getMinutes());
        return sameDay ? hm : (pad(d.getMonth() + 1) + "-" + pad(d.getDate()) + " " + hm);
      }
      function fmtRem(s) {
        if (s == null) return "";
        if (s >= 86400) return Math.floor(s / 86400) + "d " + Math.floor((s % 86400) / 3600) + "h";
        return Math.floor(s / 3600) + "h" + Math.floor((s % 3600) / 60) + "m";
      }
      function srcLetter(id) { return id === 1 ? "E" : id === 2 ? "G" : "?"; }
      function poolMax(accs, dim) {
        var ok = (accs || []).filter(function (a) { return a.ok; });
        if (!ok.length) return null;
        ok.sort(function (a, b) {
          return (b.usage[dim].utilization || 0) - (a.usage[dim].utilization || 0);
        });
        var top = ok[0].usage[dim];
        return { pct: top.utilization, rem: top.remaining_seconds, id: ok[0].id };
      }

      function render(data) {
        var fh = poolMax(data.accounts, "five_hour");
        var wk = poolMax(data.accounts, "seven_day");
        fiveEl.textContent = fh ? "5h " + fh.pct + "% · " + fmtRem(fh.rem) + " " + srcLetter(fh.id) : "5h --";
        sevenEl.textContent = wk ? "week " + wk.pct + "% · " + fmtRem(wk.rem) + " " + srcLetter(wk.id) : "week --";
        lastEl.textContent = fmtTime(new Date()) + " · " + (data.source || "?");
      }

      function showAuthNeeded() {
        fiveEl.textContent = "未授权";
        sevenEl.textContent = "";
        lastEl.innerHTML = '<a href="' + BASE + '/health" target="_blank" rel="noopener" class="usage-link">登录</a>';
      }
      function showFail(label) {
        fiveEl.textContent = label;
        sevenEl.textContent = "";
        lastEl.textContent = fmtTime(new Date()) + " (失败)";
      }

      function call(method) {
        btn.disabled = true;
        var url = BASE + (method === "POST" ? "/refresh" : "/usage");
        fetch(url, { method: method, credentials: "include" })
          .then(function (r) {
            var ct = r.headers.get("content-type") || "";
            if (!r.ok || ct.indexOf("json") === -1) {
              showAuthNeeded();
              return null;
            }
            return r.json();
          })
          .then(function (j) {
            if (j) render(j);
          })
          .catch(function () { showFail("网络错误"); })
          .finally(function () { btn.disabled = false; });
      }

      btn.addEventListener("click", function () { call("POST"); });
      call("GET");
    })();
  </script>
  <div slot="footer-extra" id="user-mgmt-row">
    <span class="lbl">User Management</span>
    <a class="um-cfa-only" href="https://admin.neckbozia.com" target="_blank" rel="noopener">CFA</a>
    <span class="sep um-cfa-only">·</span>
    <a id="um-authelia"
       data-cfa="/authelia/"
       data-authelia="https://users.neckbozia.com:66/"
       target="_blank" rel="noopener">Authelia</a>
  </div>
  <style slot="footer-extra" is:global>
    /* OTP strip + user mgmt row — 字号比 footer 大一档，inner DOM 由 JS 注入故 is:global */
    #otp-section {
      margin: 0;
      padding: 14px 0 0;
      border-top: 1px solid var(--border);
      font-size: 13px;
      color: #999;
      font-variant-numeric: tabular-nums;
      line-height: 1.7;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    #otp-list { flex: 1; min-width: 0; text-align: center; }
    #otp-controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
      font-size: 12px;
      color: #888;
    }
    #otp-last-refresh { font-variant-numeric: tabular-nums; }
    #otp-refresh-btn {
      background: transparent;
      border: none;
      padding: 2px 4px;
      font-size: 16px;
      line-height: 1;
      color: #888;
      cursor: pointer;
      font-family: inherit;
    }
    #otp-refresh-btn:hover { color: var(--accent); }
    #otp-refresh-btn:disabled {
      opacity: 0.5;
      cursor: wait;
    }
    #otp-section .otp-row { display: block; }
    #otp-section .otp-empty { font-size: 13px; color: #999; }
    #otp-section .otp-link {
      color: #888;
      text-decoration: none;
      border-bottom: 1px dotted #bbb;
    }
    #otp-section .otp-link:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
    #user-mgmt-row {
      text-align: center;
      padding: 0 0 8px;
      font-size: 13px;
      color: #888;
    }
    #user-mgmt-row .lbl { color: #888; margin-right: 8px; }
    #user-mgmt-row .sep { margin: 0 4px; color: #bbb; }
    #user-mgmt-row a {
      color: #888;
      text-decoration: none;
      border-bottom: 1px dotted #bbb;
    }
    #user-mgmt-row a:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
  </style>
  <script is:inline slot="footer-extra">
    (function () {
      var lastEl = document.getElementById("otp-last-refresh");
      var btn = document.getElementById("otp-refresh-btn");
      var listEl = document.getElementById("otp-list");

      function pad(n) { return String(n).padStart(2, "0"); }
      function fmtTime(d) {
        var n = new Date();
        var sameDay = d.getFullYear() === n.getFullYear() && d.getMonth() === n.getMonth() && d.getDate() === n.getDate();
        var hm = pad(d.getHours()) + ":" + pad(d.getMinutes());
        return sameDay ? hm : (pad(d.getMonth() + 1) + "-" + pad(d.getDate()) + " " + hm);
      }

      function render(items) {
        if (!items.length) {
          listEl.innerHTML = '<span class="otp-empty">no notifications</span>';
          return;
        }
        listEl.innerHTML = items.map(function (it) {
          var parts = [];
          if (it.ts) parts.push(it.ts);
          if (it.subject) parts.push(it.subject);
          if (it.to) parts.push("→ " + it.to);
          if (it.otp) parts.push(it.otp);
          if (it.link) parts.push('<a class="otp-link" href="' + it.link + '" target="_blank" rel="noopener noreferrer">open link</a>');
          return '<div class="otp-row">' + parts.join(" · ") + "</div>";
        }).join("");
      }

      function load() {
        btn.disabled = true;
        fetch("/_notifications.json", { credentials: "same-origin" })
          .then(function (r) { return r.ok ? r.json() : { items: [] }; })
          .then(function (j) {
            render(j.items || []);
            lastEl.textContent = fmtTime(new Date());
          })
          .catch(function () {
            listEl.innerHTML = '<span class="otp-empty">读取失败</span>';
            lastEl.textContent = fmtTime(new Date()) + " (失败)";
          })
          .finally(function () { btn.disabled = false; });
      }

      btn.addEventListener("click", load);
      load();
    })();

    /* User Management 行跟 layout 顶部 tab 联动 */
    (function () {
      var KEY = "dashTab";
      var anchor = document.getElementById("um-authelia");
      function apply(tab) {
        document.querySelectorAll("#user-mgmt-row .um-cfa-only").forEach(function (el) {
          el.style.display = tab === "cfa" ? "" : "none";
        });
        if (anchor) anchor.href = anchor.dataset[tab] || "#";
      }
      var saved = "authelia";
      try { saved = localStorage.getItem(KEY) || "authelia"; } catch (e) {}
      apply(saved);
      document.querySelectorAll(".tabs button").forEach(function (b) {
        b.addEventListener("click", function () { apply(b.dataset.tab); });
      });
    })();
  </script>
</Dashboard>
