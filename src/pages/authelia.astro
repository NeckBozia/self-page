---
// Authelia user mgmt page — admin tier 内（CF Access 主 app policy 覆盖根 + 子路径）
const buildTime = new Date().toISOString();
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>User Management — Authelia</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style>
      :root {
        --bg: #ffffff;
        --fg: #1a1a1a;
        --muted: #6a6a72;
        --card: #fafafa;
        --card-hover: #f0f0f2;
        --border: #e4e4e7;
        --border-hover: #a8a8b0;
        --accent: #4a8a9c;
        --danger: #b14a4a;
      }
      * { box-sizing: border-box; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      header {
        max-width: 1024px;
        width: 100%;
        margin: 0 auto;
        padding: 20px 32px 0;
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 24px;
      }
      h1 {
        font-size: 14px;
        font-weight: 500;
        color: var(--muted);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 0;
      }
      header a.nav {
        font-size: 12px;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.04em;
      }
      header a.nav:hover { color: var(--fg); }
      main {
        max-width: 1024px;
        width: 100%;
        margin: 0 auto;
        padding: 24px 32px 40px;
        flex: 1;
      }
      .toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
      }
      .toolbar h2 {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.16em;
        text-transform: uppercase;
        margin: 0;
      }
      button {
        padding: 7px 14px;
        font: inherit;
        font-size: 12px;
        color: var(--fg);
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        transition: border-color 160ms ease, background 160ms ease;
        letter-spacing: 0.02em;
      }
      button:hover { border-color: var(--border-hover); background: var(--card); }
      button.primary {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
      }
      button.primary:hover { background: #3d7585; border-color: #3d7585; }
      button.danger { color: var(--danger); border-color: #d8b4b4; }
      button.danger:hover { background: #fff0f0; }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
      }
      th, td {
        padding: 10px 14px;
        text-align: left;
        border-bottom: 1px solid var(--border);
      }
      tr:last-child td { border-bottom: none; }
      th {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: var(--card);
      }
      td.actions { text-align: right; white-space: nowrap; }
      td.actions button { font-size: 11px; padding: 5px 10px; margin-left: 4px; }
      td .badge {
        display: inline-block;
        padding: 2px 8px;
        font-size: 10px;
        border-radius: 4px;
        background: var(--card-hover);
        color: var(--muted);
        margin-right: 4px;
      }
      td .badge.disabled {
        background: #fbe4e4;
        color: var(--danger);
      }
      td .badge.enabled {
        background: #e4f4ec;
        color: #3a8a5a;
      }
      td.empty {
        text-align: center;
        padding: 32px;
        color: var(--muted);
        font-style: italic;
      }
      dialog {
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 24px;
        min-width: 360px;
        max-width: 480px;
      }
      dialog::backdrop { background: rgba(0,0,0,0.35); }
      dialog h2 {
        margin: 0 0 14px;
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      dialog form label {
        display: block;
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 10px;
      }
      dialog form input {
        display: block;
        width: 100%;
        margin-top: 4px;
        padding: 7px 10px;
        font: inherit;
        font-size: 13px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--bg);
        color: var(--fg);
      }
      dialog form input:focus {
        outline: none;
        border-color: var(--accent);
      }
      dialog menu {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        margin: 16px 0 0;
        padding: 0;
      }
      .toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        padding: 10px 16px;
        font-size: 12px;
        border-radius: 6px;
        background: var(--fg);
        color: var(--bg);
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 160ms ease, transform 160ms ease;
        pointer-events: none;
        z-index: 100;
      }
      .toast.show { opacity: 1; transform: translateY(0); }
      .toast.error { background: var(--danger); }
      footer {
        text-align: center;
        padding: 16px;
        font-size: 11px;
        color: #999;
        font-variant-numeric: tabular-nums;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>User Management / Authelia</h1>
      <a class="nav" href="/">← home</a>
    </header>
    <main>
      <div class="toolbar">
        <h2>用户列表</h2>
        <button class="primary" id="add-btn">+ 新建用户</button>
      </div>
      <table>
        <thead>
          <tr>
            <th>username</th>
            <th>displayname</th>
            <th>email</th>
            <th>groups</th>
            <th>status</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="tbody">
          <tr><td colspan="6" class="empty">加载中…</td></tr>
        </tbody>
      </table>
    </main>

    <dialog id="add-dialog">
      <form id="add-form">
        <h2>新建用户</h2>
        <label>username <input name="username" required pattern="[a-z0-9_-]+" autocomplete="off" /></label>
        <label>display name <input name="displayname" required autocomplete="off" /></label>
        <label>email <input type="email" name="email" required autocomplete="off" /></label>
        <label>groups (comma-sep) <input name="groups" value="users" autocomplete="off" /></label>
        <label>password <input type="password" name="password" required minlength="8" autocomplete="new-password" /></label>
        <menu>
          <button type="button" data-close="add-dialog">取消</button>
          <button type="submit" class="primary">创建</button>
        </menu>
      </form>
    </dialog>

    <dialog id="pw-dialog">
      <form id="pw-form">
        <h2>重置密码</h2>
        <label>username <input name="username" readonly /></label>
        <label>new password <input type="password" name="password" required minlength="8" autocomplete="new-password" /></label>
        <menu>
          <button type="button" data-close="pw-dialog">取消</button>
          <button type="submit" class="primary">重置</button>
        </menu>
      </form>
    </dialog>

    <div class="toast" id="toast"></div>

    <footer>built <span>{buildTime}</span> · <a href="/" style="color:#888;text-decoration:none;border-bottom:1px dotted #bbb;">home</a></footer>

    <script is:inline>
      const API = "/api/authelia-users";
      const tbody = document.getElementById("tbody");
      const toast = document.getElementById("toast");

      function showToast(msg, isError) {
        toast.textContent = msg;
        toast.classList.toggle("error", !!isError);
        toast.classList.add("show");
        setTimeout(() => toast.classList.remove("show"), 2500);
      }

      async function api(method, path, body) {
        const opts = { method, headers: { "Content-Type": "application/json" } };
        if (body) opts.body = JSON.stringify(body);
        const r = await fetch(API + path, opts);
        const text = await r.text();
        let data = null;
        try { data = text ? JSON.parse(text) : null; } catch (e) {}
        if (!r.ok) {
          const msg = (data && data.errors && data.errors.join("; ")) || `HTTP ${r.status}`;
          throw new Error(msg);
        }
        return data;
      }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, (c) => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
        }[c]));
      }

      function renderUsers(users) {
        if (!users.length) {
          tbody.innerHTML = '<tr><td colspan="6" class="empty">还没有用户</td></tr>';
          return;
        }
        tbody.innerHTML = users.map((u) => {
          const groups = (u.groups || []).map((g) => `<span class="badge">${escapeHtml(g)}</span>`).join("");
          const status = u.disabled
            ? '<span class="badge disabled">disabled</span>'
            : '<span class="badge enabled">enabled</span>';
          return `<tr data-username="${escapeHtml(u.username)}">
            <td><code>${escapeHtml(u.username)}</code></td>
            <td>${escapeHtml(u.displayname || "")}</td>
            <td>${escapeHtml(u.email || "")}</td>
            <td>${groups}</td>
            <td>${status}</td>
            <td class="actions">
              <button data-act="toggle">${u.disabled ? "启用" : "停用"}</button>
              <button data-act="pw">改密</button>
              <button data-act="del" class="danger">删除</button>
            </td>
          </tr>`;
        }).join("");
      }

      async function load() {
        try {
          const d = await api("GET", "/users");
          renderUsers(d.users || []);
        } catch (e) {
          tbody.innerHTML = `<tr><td colspan="6" class="empty">读取失败: ${escapeHtml(e.message)}</td></tr>`;
        }
      }

      // Close dialogs
      document.querySelectorAll("[data-close]").forEach((b) => {
        b.addEventListener("click", () => {
          const id = b.getAttribute("data-close");
          document.getElementById(id).close();
        });
      });

      // Add user
      const addDialog = document.getElementById("add-dialog");
      const addForm = document.getElementById("add-form");
      document.getElementById("add-btn").addEventListener("click", () => {
        addForm.reset();
        addForm.elements.groups.value = "users";
        addDialog.showModal();
      });
      addForm.addEventListener("submit", async (ev) => {
        ev.preventDefault();
        const fd = new FormData(addForm);
        const groups = String(fd.get("groups") || "").split(",").map((s) => s.trim()).filter(Boolean);
        try {
          await api("POST", "/users", {
            username: fd.get("username"),
            displayname: fd.get("displayname"),
            email: fd.get("email"),
            groups,
            password: fd.get("password"),
          });
          addDialog.close();
          showToast("用户已创建");
          load();
        } catch (e) {
          showToast(e.message, true);
        }
      });

      // Reset password
      const pwDialog = document.getElementById("pw-dialog");
      const pwForm = document.getElementById("pw-form");
      pwForm.addEventListener("submit", async (ev) => {
        ev.preventDefault();
        const fd = new FormData(pwForm);
        const u = fd.get("username");
        try {
          await api("POST", `/users/${encodeURIComponent(u)}/password`, { password: fd.get("password") });
          pwDialog.close();
          showToast(`已重置 ${u} 的密码`);
        } catch (e) {
          showToast(e.message, true);
        }
      });

      // Row actions
      tbody.addEventListener("click", async (ev) => {
        const btn = ev.target.closest("button[data-act]");
        if (!btn) return;
        const tr = btn.closest("tr");
        const u = tr.getAttribute("data-username");
        const act = btn.getAttribute("data-act");
        if (act === "del") {
          if (!confirm(`删除用户 ${u}？此操作不可撤销。`)) return;
          try {
            await api("DELETE", `/users/${encodeURIComponent(u)}`);
            showToast(`已删除 ${u}`);
            load();
          } catch (e) {
            showToast(e.message, true);
          }
        } else if (act === "pw") {
          pwForm.reset();
          pwForm.elements.username.value = u;
          pwDialog.showModal();
        } else if (act === "toggle") {
          const isDisabled = btn.textContent.trim() === "启用";
          try {
            await api("PATCH", `/users/${encodeURIComponent(u)}`, { disabled: !isDisabled });
            showToast(`${u} 已${isDisabled ? "启用" : "停用"}`);
            load();
          } catch (e) {
            showToast(e.message, true);
          }
        }
      });

      load();
    </script>
  </body>
</html>
