---
import Dashboard from "../layouts/Dashboard.astro";

// hm.neckbozia.com:66 —— 家公网 :66 + Authelia / gateway nginx 直连链路（灰云短名，快）。
// CF Tunnel + CF Access 链路的卡片在 admin.astro（home.neckbozia.com）。
// DSM / WebDAV / OhMyAPI 只有一条路径，两页都有。
const sections = [
  {
    title: "Ruoyi OA",
    items: [
      {
        name: "Ruoyi OA",
        desc: "OA 后台 — admin SPA",
        href: "https://ry.neckbozia.com:66",
      },
      {
        name: "Spring Boot Admin",
        desc: "ruoyi-server 实时监控",
        href: "https://ryl.neckbozia.com:66/admin/applications",
      },
      {
        name: "Grafana",
        desc: "性能监控 / PVE + 容器指标",
        href: "https://gfn.neckbozia.com:66",
      },
    ],
  },
  {
    title: "Services",
    items: [
      {
        name: "mihomo",
        desc: "metacubexd — 代理面板 / 流量 / 规则命中",
        href: "https://mhn.neckbozia.com:66/ui/metacubexd/",
      },
      {
        name: "Cloud CLi",
        desc: "AI 编程助手 — 浏览器内编程",
        href: "https://cc.neckbozia.com:66",
      },
      {
        name: "知识库",
        desc: "Quartz personal KB",
        href: "https://kb.neckbozia.com:66",
      },
      {
        name: "OhMyAPI",
        desc: "Claude 中转",
        href: "https://ai.neckbozia.com/admin",
      },
    ],
  },
  {
    title: "Synology",
    items: [
      {
        name: "DSM",
        desc: "Synology 管理面板",
        href: "https://dsm.neckbozia.com:66",
      },
      {
        name: "qBittorrent",
        desc: "qb WebUI",
        href: "https://qb.neckbozia.com:66/",
      },
      {
        name: "Transmission",
        desc: "tr WebUI",
        href: "https://tr.neckbozia.com:66/transmission/web/",
      },
      {
        // WebDAV 是挂载协议、非浏览器 UI，所以做成「点击复制地址」的 copy 卡
        name: "WebDAV",
        desc: "点击复制地址",
        copy: "https://wd.neckbozia.com:66",
      },
    ],
  },
];
---

<Dashboard
  pageTitle="HM"
  headerLabel="NeckBozia"
  brandMixed={true}
  sections={sections}
  footerLinks={[
    { href: "https://auth.neckbozia.com:66", label: "Authelia Portal" },
    { href: "https://auth.neckbozia.com:66/logout", label: "logout" },
  ]}
>
  <script is:inline slot="footer-extra">
    /* 卡片点击量统计：mousedown 时 sendBeacon，不阻塞 target=_blank 跳转 */
    (function () {
      document.querySelectorAll("a.card").forEach(function (c) {
        c.addEventListener("mousedown", function () {
          var n = c.querySelector(".name");
          var name = n && n.textContent ? n.textContent.trim() : "";
          if (!name) return;
          try {
            navigator.sendBeacon(
              "/__click",
              new Blob([JSON.stringify({ name: name })], { type: "application/json" })
            );
          } catch (e) {}
        });
      });
    })();
  </script>
  <div slot="footer-extra" id="user-mgmt-row">
    <span class="lbl">User Management</span>
    <a href="https://users.neckbozia.com:66/" target="_blank" rel="noopener">Authelia</a>
  </div>
  <style slot="footer-extra" is:global>
    #user-mgmt-row {
      text-align: center;
      padding: 0 0 8px;
      font-size: 13px;
      color: #888;
    }
    #user-mgmt-row .lbl { color: #888; margin-right: 8px; }
    #user-mgmt-row a {
      color: #888;
      text-decoration: none;
      border-bottom: 1px dotted #bbb;
    }
    #user-mgmt-row a:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
  </style>
</Dashboard>
