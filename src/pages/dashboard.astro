---
import "../styles/global.css";

const apps = [
  { name: "Claude Code",       href: "https://cc.neckbozia.com",       desc: "AI 编程助手" },
  { name: "Yudao OA",          href: "https://ruoyi.neckbozia.com",    desc: "OA 后台" },
  { name: "Spring Boot Admin", href: "https://ruoyilog.neckbozia.com", desc: "监控" },
  { name: "知识库",            href: "https://kb.neckbozia.com",       desc: "Quartz" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Dashboard</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style>
      body {
        background: #0e0e10;
        color: #e6e6e6;
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 80px 24px 40px;
        flex: 1;
        width: 100%;
        box-sizing: border-box;
      }
      h1 {
        font-size: 18px;
        font-weight: 400;
        color: #888;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin: 0 0 32px;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 14px;
      }
      a.card {
        display: block;
        padding: 22px 20px;
        background: #18181b;
        border: 1px solid #26262a;
        border-radius: 10px;
        color: inherit;
        text-decoration: none;
        transition: border-color 120ms ease, transform 120ms ease, background 120ms ease;
      }
      a.card:hover {
        border-color: #4a4a55;
        background: #1d1d22;
        transform: translateY(-1px);
      }
      .name {
        font-size: 16px;
        font-weight: 500;
        margin: 0 0 4px;
      }
      .desc {
        font-size: 13px;
        color: #888;
        margin: 0;
      }
      footer {
        text-align: center;
        padding: 24px;
        font-size: 12px;
        color: #555;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Dashboard</h1>
      <div class="grid">
        {apps.map((app) => (
          <a class="card" href={app.href}>
            <p class="name">{app.name}</p>
            <p class="desc">{app.desc}</p>
          </a>
        ))}
      </div>
    </main>
    <footer>Astro</footer>
  </body>
</html>
